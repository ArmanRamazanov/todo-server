{
  "version": "0.2.0",
  "configirations": {
    "name": "Run tsx in VSCode Debugger",
    "type": "node",
    "request": "launch",
    "runtimeExecutable": "node",
    "runtimeArgs": ["--loader", "tsx"],
    "args": ["${file}"],
    "cwd": "${workspaceRoot}",
    "internalConsoleOptions": "openOnSessionStart",
    "skipFiles": ["<node_internals>/**", "node_modules/**"]
  }
}
